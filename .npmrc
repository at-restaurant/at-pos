# .npmrc - Configure native module builds

# Enable shamefully-hoist for pnpm (helps with native modules)
shamefully-hoist=true

# Use strict peer dependencies
strict-peer-dependencies=false

# Node-gyp configuration
python=python3

# Electron configuration
target_arch=x64
runtime=electron
disturl=https://electronjs.org/headers

# Build configuration
build_from_source=true

# Logging
loglevel=warn

# Windows-specific (GitHub Actions will override if needed)
# msvs_version=2022