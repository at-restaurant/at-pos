{
  "name": "at-restaurant-pos",
  "version": "2.0.0",
  "description": "Universal Restaurant POS with Multi-Platform Printing",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check",
    "format": "biome format --write",
    "type-check": "tsc --noEmit",
    "printer": "node printer-service/server.js",
    "dev:all": "concurrently -k -n PRINTER,NEXT -c magenta,cyan \"node printer-service/server.js\" \"next dev\"",
    "clean": "rm -rf .next node_modules/.cache dist out",
    "postinstall": "electron-builder install-app-deps",
    "electron:dev": "concurrently -k -n NEXT,ELECTRON -c cyan,blue \"next dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "cross-env BUILD_ELECTRON=true next build && electron-builder",
    "electron:build:x64": "cross-env BUILD_ELECTRON=true next build && electron-builder --x64",
    "electron:build:ia32": "cross-env BUILD_ELECTRON=true next build && electron-builder --ia32",
    "electron:build:all": "cross-env BUILD_ELECTRON=true next build && electron-builder --x64 --ia32",
    "electron:start": "electron .",
    "rebuild:printer:x64": "electron-rebuild -f -w printer --arch=x64",
    "rebuild:printer:ia32": "electron-rebuild -f -w printer --arch=ia32"
  },
  "dependencies": {
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.87.1",
    "bcryptjs": "^3.0.3",
    "body-parser": "^2.2.1",
    "cloudinary": "^2.8.0",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "html2canvas": "^1.4.1",
    "lucide-react": "^0.561.0",
    "next": "16.0.10",
    "printer": "^0.4.0",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "recharts": "^3.6.0",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "electron-rebuild": "^3.2.9",
    "tailwindcss": "^4.0.0",
    "typescript": "^5",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "com.atrestaurant.pos",
    "productName": "AT Restaurant POS",
    "directories": {
      "output": "dist",
      "buildResources": "public"
    },
    "files": [
      "electron/**/*",
      "out/**/*",
      "public/icons/**/*",
      "printer-service/**/*",
      "!printer-service/node_modules",
      "node_modules/printer/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64", "ia32"]
        },
        {
          "target": "zip",
          "arch": ["x64", "ia32"]
        }
      ],
      "icon": "public/icons/icon-512.png",
      "requestedExecutionLevel": "requireAdministrator",
      "artifactName": "${productName}-Setup-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AT Restaurant POS",
      "installerIcon": "public/icons/icon-512.png",
      "uninstallerIcon": "public/icons/icon-512.png",
      "perMachine": true,
      "artifactName": "${productName}-Setup-${arch}.${ext}",
      "deleteAppDataOnUninstall": false
    },
    "extraResources": [
      {
        "from": "printer-service",
        "to": "printer-service",
        "filter": ["**/*", "!node_modules"]
      }
    ],
    "afterPack": "./build/afterPack.js"
  },
  "engines": {
    "node": ">=18.17.0",
    "npm": ">=9.0.0"
  }
}